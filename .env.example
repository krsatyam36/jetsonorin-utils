# Server
PORT=5000
HOST=0.0.0.0

# Camera
CAMERA_DEVICE=/dev/video0
FRAME_WIDTH=1920
FRAME_HEIGHT=1080
FRAME_RATE=30

# Model
YOLO_MODEL=yolo11n.pt
YOLO_MODEL_TYPE=ultralytics
YOLO_DEVICE=cuda:0

# Detectors (default off, toggle via web UI)
ENABLE_YOLO=false
ENABLE_FACE=false
ENABLE_MOTION=false

# Face detection
FACE_METHOD=haar

# Motion detection
MOTION_METHOD=mog2
MOTION_MIN_AREA=500

# Confidence
CONFIDENCE_THRESHOLD=0.5

# Auth (optional)
AUTH_ENABLED=false
AUTH_USERNAME=admin
AUTH_PASSWORD=changeme

# Rate limiting
RATE_LIMIT=100
RATE_LIMIT_WINDOW=60

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=logs/stream.log
